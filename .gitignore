# ============================================================
# Access Dependency Analyzer
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# --- 仮想環境 ---
.venv/
venv/
env/
ENV/

# --- uv ---
.uv/
uv.lock

# --- テスト / カバレッジ ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- IDE / エディタ ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
Desktop.ini
.DS_Store

# --- ログ ---
*.log
logs/

# --- 解析結果（自動生成） ---
output/*
!output/.gitkeep
analysis/

# --- Access データベース（誤コミット防止） ---
*.accdb
*.mdb
*.laccdb
*.accde
*.mde

# --- 一時ファイル ---
*.tmp
*.temp
~$*
